generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"] // REQUIRED for Render
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RecordType {
  INCOME
  EXPENSE
}

model User {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  password  String
  role      Role        @default(VIEWER)
  status    UserStatus  @default(ACTIVE)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  records   FinancialRecord[] @relation("UserRecords")
}

model FinancialRecord {
  id          String      @id @default(cuid())
  amount      Float
  type        RecordType
  category    String
  date        DateTime
  note        String?

  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  createdById String
  createdBy   User        @relation("UserRecords", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([type])
  @@index([date])
}